  "typography": {
    "fontFamily": {
      "sans":  { "value": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif", "description": "UI text" },
      "mono":  { "value": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace", "description": "Code, data, terminal" }
    },
    "fontSize": {
      "xs":   { "value": "0.75rem",  "px": 12, "description": "Captions, badges" },
      "sm":   { "value": "0.875rem", "px": 14, "description": "Secondary text, labels" },
      "base": { "value": "1rem",     "px": 16, "description": "Body text" },
      "lg":   { "value": "1.125rem", "px": 18, "description": "Subheadings" },
      "xl":   { "value": "1.25rem",  "px": 20, "description": "Section titles" },
      "2xl":  { "value": "1.5rem",   "px": 24, "description": "Page headings" },
      "3xl":  { "value": "1.875rem", "px": 30, "description": "Hero headings" },
      "4xl":  { "value": "2.25rem",  "px": 36, "description": "Display headings" }
    },
    "fontWeight": {
      "regular":  { "value": 400 },
      "medium":   { "value": 500 },
      "semibold": { "value": 600 },
      "bold":     { "value": 700 }
    },
    "lineHeight": {
      "tight":   { "value": 1.25, "description": "Headings" },
      "snug":    { "value": 1.375, "description": "Subheadings" },
      "normal":  { "value": 1.5, "description": "Body text" },
      "relaxed": { "value": 1.625, "description": "Long-form content" },
      "loose":   { "value": 2.0, "description": "Spacious layouts" }
    },
    "letterSpacing": {
      "tighter": { "value": "-0.02em" },
      "tight":   { "value": "-0.01em" },
      "normal":  { "value": "0em" },
      "wide":    { "value": "0.025em" },
      "wider":   { "value": "0.05em", "description": "All-caps labels" }
    }
  },

  "spacing": {
    "description": "Spacing scale based on 4px base unit. Usage: padding, margin, gap.",
    "0":  { "value": "0px" },
    "1":  { "value": "4px" },
    "2":  { "value": "8px" },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "5":  { "value": "20px" },
    "6":  { "value": "24px" },
    "8":  { "value": "32px" },
    "10": { "value": "40px" },
    "12": { "value": "48px" },
    "16": { "value": "64px" },
    "20": { "value": "80px" },
    "24": { "value": "96px" },
    "32": { "value": "128px" },
    "40": { "value": "160px" },
    "48": { "value": "192px" },
    "64": { "value": "256px" }
  },

  "borderRadius": {
    "none": { "value": "0px" },
    "sm":   { "value": "4px" },
    "md":   { "value": "8px" },
    "lg":   { "value": "12px" },
    "xl":   { "value": "16px" },
    "full": { "value": "9999px" }
  },

  "shadow": {
    "description": "Shadow tokens optimized for dark mode surfaces. Use sparingly -- dark UIs rely more on surface color elevation than shadow.",
    "sm": {
      "value": "0 1px 2px 0 rgba(0, 0, 0, 0.3)",
      "description": "Subtle lift for cards"
    },
    "md": {
      "value": "0 4px 6px -1px rgba(0, 0, 0, 0.4), 0 2px 4px -2px rgba(0, 0, 0, 0.3)",
      "description": "Dropdowns, popovers"
    },
    "lg": {
      "value": "0 10px 15px -3px rgba(0, 0, 0, 0.5), 0 4px 6px -4px rgba(0, 0, 0, 0.4)",
      "description": "Dialogs, modals"
    },
    "xl": {
      "value": "0 20px 25px -5px rgba(0, 0, 0, 0.6), 0 8px 10px -6px rgba(0, 0, 0, 0.5)",
      "description": "Elevated overlays, command palette"
    }
  },

  "transition": {
    "fast": {
      "duration": { "value": "150ms" },
      "easing":   { "value": "ease-out" },
      "description": "Micro-interactions: buttons, toggles, checkboxes"
    },
    "normal": {
      "duration": { "value": "200ms" },
      "easing":   { "value": "ease-in-out" },
      "description": "Panel transitions, expand/collapse"
    },
    "slow": {
      "duration": { "value": "300ms" },
      "easing":   { "value": "ease-in-out" },
      "description": "Page transitions, modal open/close"
    }
  },

  "zIndex": {
    "base":     { "value": 0, "description": "Default stacking context" },
    "dropdown": { "value": 100, "description": "Select menus, autocomplete" },
    "sticky":   { "value": 200, "description": "Sticky headers, toolbars" },
    "modal":    { "value": 300, "description": "Modal dialogs and backdrops" },
    "popover":  { "value": 400, "description": "Popovers, tooltips" },
    "toast":    { "value": 500, "description": "Toast notifications (always on top)" }
  },

  "breakpoint": {
    "mobile":     { "value": "640px" },
    "tablet":     { "value": "768px" },
    "desktop":    { "value": "1024px" },
    "wide":       { "value": "1280px" },
    "ultra-wide": { "value": "1536px" }
