        "subtle":  { "value": "#F1F5F9", "description": "slate-100 - Hover, dividers" }
      }
    },
    "text": {
      "dark": {
        "primary":   { "value": "#F8FAFC", "description": "slate-50" },
        "secondary": { "value": "#94A3B8", "description": "slate-400" },
        "tertiary":  { "value": "#64748B", "description": "slate-500" },
        "disabled":  { "value": "#475569", "description": "slate-600" }
